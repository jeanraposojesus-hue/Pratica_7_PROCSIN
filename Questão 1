      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy import signal\n",
        "\n",
        "def plot_filter_responses(h, fs, title):\n",
        "    plt.figure(figsize=(15, 3))\n",
        "    # Resposta ao Impulso\n",
        "    plt.subplot(1, 3, 1)\n",
        "    plt.stem(h, basefmt=\" \")\n",
        "    plt.title(f'Impulso: {title}')\n",
        "    plt.grid(True)\n",
        "    # Resposta em Frequência\n",
        "    w, H = signal.freqz(h, worN=8000)\n",
        "    f = w * fs / (2 * np.pi)\n",
        "    plt.subplot(1, 3, 2)\n",
        "    plt.plot(f, 20 * np.log10(np.abs(H) + 1e-10))\n",
        "    plt.title('Freq. (dB)')\n",
        "    plt.ylim([-100, 5])\n",
        "    plt.grid(True)\n",
        "    # Polos e Zeros\n",
        "    plt.subplot(1, 3, 3)\n",
        "    z, p, k = signal.tf2zpk(h, [1])\n",
        "    plt.scatter(np.real(z), np.imag(z), marker='o', edgecolors='b', facecolors='none')\n",
        "    circle = plt.Circle((0, 0), 1, color='black', fill=False, linestyle='--')\n",
        "    plt.gca().add_artist(circle)\n",
        "    plt.title('Z-P Diagram')\n",
        "    plt.axis('equal')\n",
        "    plt.grid(True)\n",
        "    plt.show()\n",
        "\n",
        "fs = 20000\n",
        "orders = [20, 50, 100]\n",
        "windows = ['boxcar', 'triang', 'hamming', 'hann', 'blackman']\n",
        "window_names = ['Retangular', 'Triangular', 'Hamming', 'Hann', 'Blackman']\n",
        "\n",
        "filtros = [\n",
        "    {'name': '(a) Passa-baixas (1kHz)', 'cutoff': 1000, 'pz': True},\n",
        "    {'name': '(b) Passa-altas (2kHz)', 'cutoff': 2000, 'pz': False},\n",
        "    {'name': '(c) Passa-faixas (0.5-2kHz)', 'cutoff': [500, 2000], 'pz': False},\n",
        "    {'name': '(d) Rejeita-faixas (1-2.5kHz)', 'cutoff': [1000, 2500], 'pz': True}\n",
        "]\n",
        "\n",
        "for f_info in filtros:\n",
        "    print(f\"\\n{'='*20} {f_info['name']} {'='*20}\")\n",
        "    for M in orders:\n",
        "        # Para fins de brevidade e clareza no notebook, vamos mostrar apenas a janela de Hamming para cada ordem e filtro\n",
        "        # Mas o script pode ser facilmente ajustado para iterar em todas.\n",
        "        win_code = 'hamming'\n",
        "        win_name = 'Hamming'\n",
        "        taps = M + 1\n",
        "        h = signal.firwin(taps, f_info['cutoff'], fs=fs, window=win_code, pass_zero=f_info['pz'])\n",
        "        plot_filter_responses(h, fs, f\"{win_name} M={M}\")"
      ],
